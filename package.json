{
  "name": "structfocus",
  "version": "0.2.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "StructFocus - LLM 上下文注意力管理引擎 (pnpm monorepo)",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b && pnpm --filter @structfocus/mcp typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench:bm25": "node packages/context/bench/search-precision.mjs",
    "clean": "pnpm -r run clean && rimraf node_modules"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@types/node": "^22.20.1",
    "eslint": "^9.39.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.6.0",
    "pnpm": ">=9.0.0"
  }
}
