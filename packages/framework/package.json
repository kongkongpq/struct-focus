{
  "name": "@struct/framework",
  "version": "0.1.0",
  "description": "Struct Bridge 地基 - EventBus/PluginManager/Pipeline/类型契约",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run --project framework",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "license": "MIT"
}
